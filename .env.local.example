# EcoTrack Environment Variables
# Copy this file to .env.local and fill in your credentials

# ── Firebase Configuration ─────────────────────────────────────────────────
# Required for cloud sync, user authentication, and global benchmarking
# Get these from: https://console.firebase.google.com → Project Settings → Web App
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abcdef

# ── Google Maps Distance Matrix API ────────────────────────────────────────
# Required for automatic commute distance computation from addresses
# Get this from: https://console.cloud.google.com → APIs → Distance Matrix API
# Note: The app works without this key (manual distance entry fallback)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ── NextAuth (Google OAuth) ─────────────────────────────────────────────────
# Required for Google Sign-In functionality
# Get from: https://console.cloud.google.com → APIs → OAuth 2.0 credentials
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate_a_random_secret_with_openssl_rand_base64_32
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret

# ── Plaid FinTech Integration ──────────────────────────────────────────────
# Required for automatic bank transaction carbon analysis
# Get from: https://dashboard.plaid.com → Team Settings → Keys
# Note: The app works without these (manual onboarding wizard fallback)
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_secret_key
PLAID_ENV=sandbox
